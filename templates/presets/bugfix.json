{
  "name": "bugfix",
  "description": "Investigate and fix a bug",
  "roles": [
    {
      "key": "investigator",
      "description": "Explores the codebase to reproduce and understand the root cause of the bug",
      "model": null,
      "allowed_tools": ["view", "glob", "grep", "explore", "edit", "create", "powershell", "task"],
      "sub_agent_policy": { "explore": true, "task": true, "general-purpose": false, "code-review": false }
    },
    {
      "key": "fixer",
      "description": "Implements the fix based on the investigator's findings",
      "model": null,
      "allowed_tools": ["view", "glob", "grep", "explore", "edit", "create", "powershell", "task"],
      "sub_agent_policy": { "explore": true, "task": true, "general-purpose": true, "code-review": false }
    },
    {
      "key": "reviewer",
      "description": "Reviews the fix for correctness, regressions, and edge cases",
      "model": null,
      "allowed_tools": ["view", "glob", "grep", "explore", "edit", "create", "powershell", "task", "code-review"],
      "sub_agent_policy": { "explore": true, "task": true, "general-purpose": false, "code-review": true }
    }
  ],
  "tasks": [
    { "id": "investigate", "title": "Reproduce the bug and identify root cause", "assigned_to": "investigator", "depends_on": [] },
    { "id": "fix", "title": "Implement the fix based on investigation findings", "assigned_to": "fixer", "depends_on": ["investigate"] },
    { "id": "review", "title": "Review the fix for correctness and regressions", "assigned_to": "reviewer", "depends_on": ["fix"] }
  ]
}
